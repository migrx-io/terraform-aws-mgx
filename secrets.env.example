# Node secrets, shared by every node (mgmt + storage).
#
# Copy this file into the stack directory you run `terraform apply` from
# (e.g. examples/pool/, examples/mgmt/) as `secrets.env` and fill in real
# values:
#
#   cp ../../secrets.env.example secrets.env
#
# It is delivered to each node at provision time (uploaded over SSH, or read
# from an SSM SecureString in ssm mode) and merged over the baked mgx-env
# (secrets win). It is NOT baked into the AMI.

# Cassandra username / password
CASS_USER=<CASS_USER>
CASS_PASSWD=<CASS_PASSWD>

# mgx gateway / node X-API keys.
MGX_GW_X_API_KEY="<X_API_KEY>"
MGX_X_API_KEY="<X_API_KEY>"

# mgx gateway admin password.
MGX_GW_ADMIN_PASSWD=<MGX_GW_ADMIN_PASSWD>

# Grafana admin user / password (used when metrics are enabled).
GRAFANA_USER=<GRAFANA_USER>
GRAFANA_PASSWD=<GRAFANA_PASSWD>
